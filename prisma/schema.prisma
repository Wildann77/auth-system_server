// Prisma Schema for Authentication System
// PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// ENUMS
// ===========================================

enum Role {
  USER
  ADMIN
}

enum Provider {
  LOCAL
  GOOGLE
}

enum OrderStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

enum OrderType {
  GENERAL
  PREMIUM_UPGRADE
}

// ===========================================
// USER MODEL
// ===========================================

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String?   // Nullable for OAuth users
  firstName        String?
  lastName         String?
  avatarUrl        String?
  role             Role      @default(USER)
  provider         Provider  @default(LOCAL)
  isEmailVerified  Boolean   @default(false)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  tokenVersion     Int       @default(0)
  isPremium        Boolean   @default(false)
  autoRenew        Boolean   @default(true)
  premiumUntil     DateTime?
  lastLoginAt      DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  emailVerificationToken EmailVerificationToken?
  passwordResetToken    PasswordResetToken?
  refreshTokens          RefreshToken[]
  orders                 Order[]

  @@index([email])
  @@index([role])
}

// ===========================================
// EMAIL VERIFICATION TOKEN
// ===========================================

model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([token])
  @@index([expiresAt])
}

// ===========================================
// PASSWORD RESET TOKEN
// ===========================================

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([token])
  @@index([expiresAt])
}

// ===========================================
// REFRESH TOKEN
// ===========================================

model RefreshToken {
  id           String   @id @default(uuid())
  token        String   @unique
  userId       String
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)

  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ===========================================
// ORDER / TRANSACTION MODEL
// ===========================================

model Order {
  id            String      @id @default(uuid())
  userId        String
  amount        Decimal     @db.Decimal(12, 2)
  status        OrderStatus @default(PENDING)
  orderType     OrderType   @default(GENERAL)
  paymentType   String?
  snapToken     String?     // For Midtrans
  snapUrl       String?     // For Midtrans
  paymentIntentId String?   // For Stripe
  externalId    String?     @unique // Gateway Transaction ID
  
  items         Json?       // Metadata about ordered items
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([externalId])
}

// ===========================================
// CONTENT MODEL
// ===========================================

model Content {
  id          String   @id @default(uuid())
  title       String
  description String?
  content     String
  contentType String   @default("text") // text, url, html
  isPremium   Boolean  @default(true)
  tags        String[] // Array of tags

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPremium])
}
